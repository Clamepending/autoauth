# Optional: canonical app URL used in curl commands and skill.md.
# Set in production so links use your real domain (e.g. https://ottoauth.example.com).
# If unset, the app uses the request Host (works for localhost and most hosts).
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# Optional: same as above (server-only; use if you don't want the URL in client bundle).
# APP_URL=https://your-production-domain.com

# Optional: base URL used by the standalone MCP proxy server.
# OTTOAUTH_BASE_URL=http://localhost:3000

# Vibe Research identity (vibe-id) — REQUIRED.
#
# Sign-in, /auth/me, credit balance, and credit charges all flow through
# the central vibe-id worker. Production points at api.accounts.vibe-research.net;
# local dev can point at a wrangler dev process.
VIBE_ID_BASE_URL=https://api.accounts.vibe-research.net
# Shared secret for /v1/* internal calls (grants, transfers, balance reads
# of users other than the caller). Get from the vibe-id deployment owner.
VIBE_ID_INTERNAL_KEY=

# Legacy Google OAuth — DEPRECATED, kept for the migration window only.
# Sign-ins now go through vibe-id (which has its own Google OAuth client).
# Old sessions still work until users sign in again, after which the new
# vibe_id_session cookie takes over. Remove these env vars after the
# Phase 3 cleanup deploy.
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# Optional: legacy user-owned fulfillment device controls. Keep this off in
# hosted OttoAuth; fulfillment workers should be internal OttoAuth infra.
# OTTOAUTH_ALLOW_USER_FULFILLMENT=0

# Required for trusted no-claim-code internal worker pairing. Set this only in
# environments where OttoAuth manages its private fulfillment fleet.
# OTTOAUTH_INTERNAL_WORKER_PAIRING_TOKEN=replace-with-a-long-random-secret

# Optional: non-browser price discovery.
# Mouser and eBay are only used when the request includes enough supplier/item
# context. JLC uses a local model because API access may be unavailable.
# OTTOAUTH_MOUSER_SEARCH_API_KEY=...
# OTTOAUTH_EBAY_ACCESS_TOKEN=...
# OTTOAUTH_JLCPCB_PRICE_MODEL_JSON={"pcb":{"base_cents":200,"per_board_cents":50,"shipping_cents":800}}
# Optional Craftcloud rough estimator. Public Craftcloud quotes still require
# uploading geometry; this model is only a low-confidence fallback when callers
# provide volume_cm3 or weight_g.
# OTTOAUTH_CRAFTCLOUD_PRICE_MODEL_JSON={"fdm":{"minimum_cents":2500,"setup_cents":500,"per_cm3_cents":90,"shipping_cents":1200,"multiplier":1.05}}

# Optional: x402 funding for agents with no linked human account or insufficient
# credits. Set pay-to to the OttoAuth receiving wallet address.
# OTTOAUTH_X402_PAY_TO=0x...
# OTTOAUTH_X402_NETWORK=eip155:84532
# OTTOAUTH_X402_FACILITATOR_URL=https://x402.org/facilitator
# OTTOAUTH_X402_DEFAULT_TOP_UP_CENTS=5000

# Turso / libsql (optional for local dev; defaults to file:./local.db)
# TURSO_DB_URL=
# TURSO_DB_AUTH_TOKEN=

# Optional: admin notifications for each submitted order.
# Slack uses an Incoming Webhook URL. SMS uses Twilio Programmable Messaging.
# SLACK_WEBHOOK_URL=
# OTTOAUTH_ADMIN_SMS_TO=+15555555555
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# Use either a from number or a Messaging Service SID.
# TWILIO_FROM_NUMBER=+15555555555
# TWILIO_MESSAGING_SERVICE_SID=MG...

# Optional: comma, semicolon, or whitespace-separated phone recipients.
# OTTOAUTH_ADMIN_SMS_TO=+15555555555
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# Use either a from number or a Messaging Service SID.
# TWILIO_FROM_NUMBER=+15555555555
# TWILIO_MESSAGING_SERVICE_SID=MG...

# Stripe secret key for Amazon order payments (placeholder $100 checkout). If unset, payment page shows "Payment not configured."
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret. Required to automatically mark orders as paid and send Slack order notifications.
# Configure Stripe to send checkout.session.completed events to:
#   https://<your-domain>/api/pay/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...
