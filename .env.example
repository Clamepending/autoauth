# Optional: canonical app URL used in curl commands and skill.md.
# Set in production so links use your real domain (e.g. https://ottoauth.example.com).
# If unset, the app uses the request Host (works for localhost and most hosts).
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# Optional: same as above (server-only; use if you don't want the URL in client bundle).
# APP_URL=https://your-production-domain.com

# Optional: base URL used by the standalone MCP proxy server.
# OTTOAUTH_BASE_URL=http://localhost:3000

# Optional: legacy user-owned fulfillment device controls. Keep this off in
# hosted OttoAuth; fulfillment workers should be internal OttoAuth infra.
# OTTOAUTH_ALLOW_USER_FULFILLMENT=0

# Required for trusted no-claim-code internal worker pairing. Set this only in
# environments where OttoAuth manages its private fulfillment fleet.
# OTTOAUTH_INTERNAL_WORKER_PAIRING_TOKEN=replace-with-a-long-random-secret

# Optional: x402 funding for agents with no linked human account or insufficient
# credits. Set pay-to to the OttoAuth receiving wallet address.
# OTTOAUTH_X402_PAY_TO=0x...
# OTTOAUTH_X402_NETWORK=eip155:84532
# OTTOAUTH_X402_FACILITATOR_URL=https://x402.org/facilitator
# OTTOAUTH_X402_DEFAULT_TOP_UP_CENTS=5000

# Turso / libsql (optional for local dev; defaults to file:./local.db)
# TURSO_DB_URL=
# TURSO_DB_AUTH_TOKEN=

# Optional: Slack Incoming Webhook URL. Agent requests are posted here. Set to different values per environment in Vercel (e.g. prod vs preview) if you want different channels.
# SLACK_WEBHOOK_URL=

# Stripe secret key for Amazon order payments (placeholder $100 checkout). If unset, payment page shows "Payment not configured."
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret. Required to automatically mark orders as paid and send Slack fulfillment notifications.
# Configure Stripe to send checkout.session.completed events to:
#   https://<your-domain>/api/pay/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...
