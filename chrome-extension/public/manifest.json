{
  "manifest_version": 3,
  "name": "Claude Browser Agent",
  "version": "1.0.0",
  "description": "AI-powered browser automation agent using Claude",
  "permissions": [
    "debugger",
    "activeTab",
    "offscreen",
    "sidePanel",
    "tabs",
    "tabGroups",
    "scripting",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": [
        "https://ottoauth.vercel.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["ottoauth-dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Claude Browser Agent"
  }
}
